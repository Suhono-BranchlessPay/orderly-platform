# Local / staging API for P1 Stage 1 (Square SANDBOX only)
#
# ❌ Do NOT put secrets here (this file is tracked).
# ❌ Do NOT put these on samurairesto.com production.
#
# Copy to artifacts/api-server/.env.local and fill from Square Sandbox dashboard.

PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://USER:PASS@127.0.0.1:5432/orderly_sandbox

TENANT_ID=samurai

SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=sandbox-sq0idb-REPLACE
SQUARE_ACCESS_TOKEN=REPLACE_SANDBOX_ACCESS_TOKEN
SQUARE_LOCATION_ID=REPLACE_SANDBOX_LOCATION_ID

# Phase A3 — API Bridge (dashboard / AI). Never commit real keys.
ORDERLY_BRIDGE_API_KEY=dev-bridge-key-change-me
ORDERLY_BRIDGE_ALLOWED_TENANTS=samurai
# ORDERLY_BRIDGE_WEBHOOK_URL=https://ai.example.com/hooks/orderly
# ORDERLY_BRIDGE_WEBHOOK_SECRET=dev-webhook-hmac-secret
# ORDERLY_CHAIN_EXPLORER_TX_BASE=https://testnet.monadvision.com/tx/

# Phase B — Dashboard auth (optional; non-production seeds master@orderly.local / manager@samurai.local)
# ORDERLY_DASHBOARD_MASTER_EMAIL=master@orderlyfoods.com
# ORDERLY_DASHBOARD_MASTER_PASSWORD=change-me
# ORDERLY_DASHBOARD_MANAGER_EMAIL=manager@samurairesto.com
# ORDERLY_DASHBOARD_MANAGER_PASSWORD=change-me
# ORDERLY_DASHBOARD_MANAGER_TENANT_ID=samurai
