# Local / staging API for P1 Stage 1 (Square SANDBOX only)
#
# ❌ Do NOT put these values on samurairesto.com production.
# ❌ Do NOT commit a filled copy of this file.
#
# Copy to artifacts/api-server/.env.local (or your process manager) and fill from
# Square Developer Dashboard → Sandbox credentials for the Samurai application.

PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://USER:PASS@127.0.0.1:5432/orderly_sandbox

# Default tenant resolution for local
TENANT_ID=samurai

# Square SANDBOX (Application ID starts with sandbox-sq0idb-...)
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=sandbox-sq0idb-REPLACE
SQUARE_ACCESS_TOKEN=REPLACE_SANDBOX_ACCESS_TOKEN
SQUARE_LOCATION_ID=REPLACE_SANDBOX_LOCATION_ID

# Optional per-tenant form (same values OK for single-tenant local):
# TENANT_SAMURAI_SQUARE_ENVIRONMENT=sandbox
# TENANT_SAMURAI_SQUARE_APPLICATION_ID=sandbox-sq0idb-REPLACE
# TENANT_SAMURAI_SQUARE_ACCESS_TOKEN=REPLACE
# TENANT_SAMURAI_SQUARE_LOCATION_ID=REPLACE

# BP optional for Stage 1 wiring proof (anchor evidence is Stage 2 / pos-native)
# BRANCHLESSPAY_LICENSE_KEY=
# BRANCHLESSPAY_ENVIRONMENT=sandbox
