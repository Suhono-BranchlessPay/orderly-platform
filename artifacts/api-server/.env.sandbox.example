# Local / staging API for P1 Stage 1 (Square SANDBOX only)
#
# ❌ Do NOT put secrets here (this file is tracked).
# ❌ Do NOT put these on samurairesto.com production.
#
# Copy to artifacts/api-server/.env.local and fill from Square Sandbox dashboard.

PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://USER:PASS@127.0.0.1:5432/orderly_sandbox

TENANT_ID=samurai

SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=sandbox-sq0idb-REPLACE
SQUARE_ACCESS_TOKEN=REPLACE_SANDBOX_ACCESS_TOKEN
SQUARE_LOCATION_ID=REPLACE_SANDBOX_LOCATION_ID

# Phase A3 — API Bridge (dashboard / AI). Never commit real keys.
ORDERLY_BRIDGE_API_KEY=dev-bridge-key-change-me
ORDERLY_BRIDGE_ALLOWED_TENANTS=samurai
# ORDERLY_BRIDGE_WEBHOOK_URL=https://ai.example.com/hooks/orderly
# ORDERLY_BRIDGE_WEBHOOK_SECRET=dev-webhook-hmac-secret
# BRANCHLESSPAY_LICENSE_KEY=REPLACE_PLATFORM_KEY
# BRANCHLESSPAY_WEBHOOK_SECRET=REPLACE_SHARED_SECRET
# BRANCHLESSPAY_MERCHANT_ID=orderly
# ORDERLY_CHAIN_EXPLORER_TX_BASE=https://testnet.monadvision.com/tx/

# Phase B — Dashboard auth (optional; non-production seeds master@orderly.local / manager@samurai.local)
# ORDERLY_DASHBOARD_MASTER_EMAIL=master@orderlyfoods.com
# ORDERLY_DASHBOARD_MASTER_PASSWORD=change-me
# ORDERLY_DASHBOARD_MANAGER_EMAIL=manager@samurairesto.com
# ORDERLY_DASHBOARD_MANAGER_PASSWORD=change-me
# ORDERLY_DASHBOARD_MANAGER_TENANT_ID=samurai

# Orderly console Host allowlist (never include restaurant client domains)
# ORDERLY_DASHBOARD_HOSTS=orderlyfoods.com,www.orderlyfoods.com,localhost,127.0.0.1

# Self-serve onboarding (Blok 3.1) — see docs/SELF_SERVE_ONBOARDING.md
# Off by default: /api/onboarding/:id/publish returns 501 until this is "1",
# and even then only creates a draft/inactive tenant shell.
# ONBOARDING_PUBLISH_ENABLED=1

# Blok 3.1 — REAL Square OAuth for self-serve onboarding. Platform Square
# APP credentials (not a restaurant's own token) — see
# docs/SELF_SERVE_ONBOARDING.md for how to register the redirect URI.
# ❌ Never commit real values here.
# SQUARE_OAUTH_APPLICATION_ID=sandbox-sq0idb-REPLACE_PLATFORM_APP_ID
# SQUARE_OAUTH_APPLICATION_SECRET=REPLACE_PLATFORM_APP_SECRET
# SQUARE_OAUTH_REDIRECT_URI=https://samurairesto.com/api/onboarding/square/callback
# SQUARE_OAUTH_ENVIRONMENT=sandbox
# 32+ byte secret used to derive an AES-256-GCM key (SHA-256) for encrypting
# Square OAuth tokens at rest. Required before /square/start will work.
# ORDERLY_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
# Optional: when set, /square/callback does a real redirect back into the
# wizard instead of rendering a standalone HTML success page.
# ONBOARDING_UI_BASE_URL=https://orderlyfoods.com

# Blok 4.1 — Social media TRIAL SKELETON (samurai only) — see docs/BLOK4_SOCIAL_TRIAL.md
# ❌ Never commit real tokens. MODE AWAL: nothing auto-sends even when all of
# these are set — /send still only ever stub-logs + audits.
# META_PAGE_ACCESS_TOKEN=REPLACE_PAGE_TOKEN
# META_APP_SECRET=REPLACE_APP_SECRET
# META_WEBHOOK_VERIFY_TOKEN=dev-verify-token-change-me
# META_PAGE_ID_TENANT_MAP_JSON={"REPLACE_PAGE_ID":"samurai"}
# SOCIAL_DEFAULT_TENANT_ID=samurai
# SOCIAL_KILL_SWITCH_SAMURAI=0
# SOCIAL_SEND_ENABLED=0
# SOCIAL_INTERNAL_API_KEY=dev-social-internal-key-change-me
